{
  "manifest_version": 3,
  "name": "Briefly — Speech ⇄ Text",
  "version": "2.0.0",
  "description": "Simple speech-to-text and text-to-speech using free browser APIs, AssemblyAI, ElevenLabs, and OpenAI.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Briefly",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "offscreen"
  ],
  "commands": {
    "push-to-talk": {
      "suggested_key": { "default": "Ctrl+Shift+Space", "mac": "Command+Shift+Space" },
      "description": "Toggle recording"
    }
  },
  "host_permissions": [
    "https://api.assemblyai.com/*",
    "https://streaming.assemblyai.com/*",
    "https://api.elevenlabs.io/*",
    "https://api.openai.com/*",
    "https://api.deepgram.com/*",
    "https://api.groq.com/*",
    "https://api.streamelements.com/*",
    "https://translate.google.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["privacy.html", "help.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
